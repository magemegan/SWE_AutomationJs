<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <connectionStrings>
    <add
      name="Restaurant"
      connectionString="Data Source=restaurant.db;Foreign Keys=True"
      providerName="Microsoft.Data.Sqlite" />
  </connectionStrings>

  <appSettings>
    <add key="Restaurant.DbPath" value="" />
    <add key="Tax.Rate" value="0.08" />
  </appSettings>
</configuration>
